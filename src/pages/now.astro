---
export const prerender = false

import Layout from '../layouts/Layout.astro'
import PageFooter from '../components/PageFooter.astro'
import Container from '../components/Container.astro'
import { NowTimeline } from '../components/now/NowTimeline'
import { getNowPosts } from '../lib/getNowPosts'

const posts = await getNowPosts()

// Get date from URL param, or default to most recent
const url = new URL(Astro.request.url)
const dateParam = url.searchParams.get('date')

// Find the matching post
let selectedPost = posts[0] // default to most recent
if (dateParam) {
  const match = posts.find((p) => p.date.slice(0, 10) === dateParam)
  if (match) {
    selectedPost = match
  }
}

const selectedDate = dateParam || (selectedPost ? selectedPost.date.slice(0, 10) : null)

function formatPublishDate(dateStr: string) {
  const date = new Date(dateStr)
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
}
---

<Layout title="Now" description="What I'm up to right now.">
  <Container className="max-w-3xl">
    <div class="px-3 md:px-0">
      <h1 class="font-handwriting text-6xl text-blue-700 mb-2 mt-0">Now</h1>
    </div>
  </Container>

  {posts.length > 1 && (
    <div class="bg-sky-100 rounded-lg mx-2 md:mx-auto md:max-w-3xl mb-6">
      <NowTimeline posts={posts} selectedDate={selectedDate} client:load />
    </div>
  )}

  <Container className="max-w-3xl">
    {selectedPost ? (
      <div class="px-3 md:px-0">
        <p class="text-sm text-gray-500 mb-6">
          Updated {formatPublishDate(selectedPost.date)}
        </p>
        <div class="prose dark:prose-invert max-w-none" set:html={selectedPost.content} />
      </div>
    ) : (
      <p class="text-gray-500 px-3 md:px-0">No updates yet.</p>
    )}
  </Container>
  <PageFooter />
</Layout>
